# Copy this file to .env.local and fill in your values

# Required — Groq (used for resume roasting)
GROQ_API_KEY=gsk_...

# Optional — OpenAI (only needed if you want image/JPG/PNG uploads)
OPENAI_API_KEY=sk-...

# Optional — Supabase (enables roast history saving)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
